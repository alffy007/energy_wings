---
import { Image } from 'astro:assets';
import qrCode from '../assets/google_qr.jpeg';
---

<section class="review-section">
    <div class="review-container">
        <h2 class="review-heading">We Value Your Feedback</h2>
        <p class="review-subtext">Your review helps us serve you better</p>

        <div class="review-card">
            <div class="stars">
                <svg class="star star-small" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="star star-medium" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="star star-large" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="star star-medium" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <svg class="star star-small" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>

            <div class="qr-wrapper">
                <Image
                    src={qrCode}
                    alt="Scan to leave a Google Review"
                    class="qr-image"
                    width={200}
                    height={200}
                />
            </div>

            <p class="scan-text">Scan QR or tap the button</p>

            <a href="https://search.google.com/local/writereview?placeid=ChIJ4fH-GhkF94YRX9nef4mMZIE" class="review-btn" target="_blank" rel="noopener noreferrer">
                <svg class="google-icon" viewBox="0 0 24 24" width="20" height="20">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Write a Review
            </a>
        </div>
    </div>
</section>

<style>
    .review-section {
        padding: 5rem 2rem;
        background: linear-gradient(180deg,
            rgba(0, 0, 0, 1) 0%,
            rgba(10, 10, 10, 1) 50%,
            rgba(0, 0, 0, 1) 100%
        );
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .review-container {
        text-align: center;
        max-width: 500px;
        margin: 0 auto;
    }

    .review-heading {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        background: linear-gradient(to right, #ffffff, #D4AF37);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .review-subtext {
        color: #ffffff;
        opacity: 0.7;
        font-size: 1.1rem;
        margin-bottom: 2.5rem;
    }

    .review-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 20px;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        transition: all 0.4s ease;
        box-shadow: 0 0 30px rgba(212, 175, 55, 0.05);
    }

    .review-card:hover {
        border-color: rgba(212, 175, 55, 0.4);
        box-shadow: 0 0 50px rgba(212, 175, 55, 0.1);
        transform: translateY(-4px);
    }

    .stars {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 0.4rem;
    }

    .star {
        color: #D4AF37;
        filter: drop-shadow(0 0 4px rgba(212, 175, 55, 0.4));
    }

    .star-small {
        width: 28px;
        height: 28px;
    }

    .star-medium {
        width: 36px;
        height: 36px;
    }

    .star-large {
        width: 44px;
        height: 44px;
    }

    .qr-wrapper {
        background: #ffffff;
        border-radius: 16px;
        padding: 1rem;
        box-shadow: 0 4px 20px rgba(212, 175, 55, 0.15);
    }

    .qr-image {
        width: 200px;
        height: 200px;
        display: block;
        border-radius: 8px;
    }

    .scan-text {
        color: #ffffff;
        font-size: 1.3rem;
        font-weight: 600;
        opacity: 0.9;
    }

    .review-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: #D4AF37;
        color: #000000;
        padding: 0.85rem 2rem;
        border-radius: 50px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
    }

    .review-btn:hover {
        background: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 255, 255, 0.2);
    }

    .google-icon {
        flex-shrink: 0;
    }

    @media (max-width: 768px) {
        .review-section {
            padding: 3rem 1.5rem;
        }

        .review-heading {
            font-size: 2rem;
        }

        .qr-image {
            width: 160px;
            height: 160px;
        }

        .scan-text {
            font-size: 1.1rem;
        }

        .star-small {
            width: 22px;
            height: 22px;
        }

        .star-medium {
            width: 28px;
            height: 28px;
        }

        .star-large {
            width: 36px;
            height: 36px;
        }
    }
</style>
